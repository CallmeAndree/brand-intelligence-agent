# Runtime 2 — Chat Analyst agent (local). Copy sang .env và điền.
# Local dùng minimax creds (VNG MaaS gateway). Trên AgentBase: gateway inject AGENT_*.
API_KEY=
BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
MINIMAX_MODEL=minimax/minimax-m2.5

# Port local. Mặc định 8080 (đúng ràng buộc AgentBase). Nếu 8080 bận trên máy
# dev → đổi (vd 8090) và set AGENT_BASE_URL ở frontend cho khớp.
PORT=8090
