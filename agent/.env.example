# Runtime 2 — Chat Analyst agent (local). Copy sang .env và điền.
# Local dùng minimax creds (VNG MaaS gateway). Trên AgentBase: gateway inject AGENT_*.
API_KEY=
BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
MINIMAX_MODEL=minimax/minimax-m2.5

# Port local. Mặc định 8080 (đúng ràng buộc AgentBase). Nếu 8080 bận trên máy
# dev → đổi (vd 8090) và set AGENT_BASE_URL ở frontend cho khớp.
PORT=8090

# Working memory: số message (user/assistant) gần nhất dựng lại thành lượt hội thoại
# gửi vào LLM (giữ mạch chỉ định "Hay hơn"). Nhỏ để chặn prompt phình token.
MEMORY_TURN_WINDOW=10
# Cắt 1 message quá dài trước khi nhét vào history (tránh artifact dài nuốt cửa sổ).
MEMORY_MESSAGE_MAX_CHARS=4000

# Runtime 1 (ingest/generation/query) — RT2 gọi để sinh nội dung (/generate) + truy
# data (/query/*) + lấy persona (/prompts/chat-system). Không có → skill/tool degrade.
RUNTIME1_BASE_URL=
RUNTIME1_API_TOKEN=
