API_KEY=""
BASE_URL="https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1"
GEMMA_MODEL="google/gemma-4-31b-it"
MINIMAX_MODEL="minimax/minimax-m2.5"
MONGODB_URI="mongodb://mongo:27017/brand_intel_dev"
MONGO_DB="brand_intel_dev"
WEBHOOK_TOKEN="change-me"
WORKER_CONCURRENCY=4
# embedding dung chung BASE_URL + API_KEY o tren
# embedding khong can key rieng
EMBEDDING_MODEL="greennode/greennode-embedding-large-1007"

# Gán cụm incremental online (topic + keyword) trong worker sau khi enrich.
INCREMENTAL_CLUSTERING_ENABLED=true
CLUSTER_COSINE_THRESHOLD=0.6
KEYWORD_COSINE_THRESHOLD=0.65
